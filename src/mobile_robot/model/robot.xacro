<?xml version="1.0" ?>
<robot name="robot" xmlns:xacro="http://www.ros.org/wiki/xacro">

<!-- Geometry and Constants -->
<xacro:property name="pi_const" value="3.14159265"/>

<!-- Body Dimensions -->
<xacro:property name="a" value="0.55663" />   <!-- length (x) -->
<xacro:property name="b" value="0.14044" />   <!-- height (z) -->
<xacro:property name="c" value="0.388"   />   <!-- width  (y) -->

<!-- Wheel Dimensions -->
<xacro:property name="r" value="0.035" />     <!-- wheel radius -->
<xacro:property name="d" value="0.04"  />     <!-- wheel thickness -->

<!-- Offsets -->
<xacro:property name="s1" value="${b/2+r}"/>         <!-- body center z above ground -->
<xacro:property name="s2" value="${a/2-r}"/>         <!-- wheel x offset from body center (front/rear) -->
<xacro:property name="s4" value="${c/2+d/2}"/>       <!-- wheel y offset (left/right) -->

<!-- Material Density -->
<xacro:property name="d1" value="2710.0"/>   <!-- body (aluminium) -->
<xacro:property name="d2" value="2710.0"/>   <!-- wheel -->

<!-- Mass -->
<xacro:property name="m1" value="${d1*a*b*c}"/>              <!-- body mass -->
<xacro:property name="m2" value="${d2*pi_const*r*r*d}"/>     <!-- wheel mass (fixed: added *d) -->

<!-- Body Inertia -->
<xacro:property name="Ix_body" value="${(1/12)*m1*(b*b+c*c)}"/>
<xacro:property name="Iy_body" value="${(1/12)*m1*(a*a+b*b)}"/>
<xacro:property name="Iz_body" value="${(1/12)*m1*(a*a+c*c)}"/>

<!-- Wheel Inertia -->
<xacro:property name="Iz_wheel" value="${0.5*m2*r*r}"/>
<xacro:property name="I_wheel"  value="${(1.0/12.0)*m2*(3.0*r*r+d*d)}"/>

<!-- Inertia macro: body -->
<xacro:macro name="inertia_body">
    <inertial>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <mass value="${m1}"/>
        <inertia ixx="${Ix_body}" ixy="0.0" ixz="0.0"
                 iyy="${Iy_body}" iyz="0.0"
                 izz="${Iz_body}"/>
    </inertial>
</xacro:macro>

<!-- Inertia macro: wheel -->
<xacro:macro name="inertia_wheel">
    <inertial>
        <origin rpy="1.570795 0 0" xyz="0 0 0"/>
        <mass value="${m2}"/>
        <inertia ixx="${I_wheel}" ixy="0.0" ixz="0.0"
                 iyy="${I_wheel}" iyz="0.0"
                 izz="${Iz_wheel}"/>
    </inertial>
</xacro:macro>

<!-- Include Gazebo file -->
<xacro:include filename="$(find mobile_robot)/model/robot.gazebo"/>

<!-- Fictitious base link -->
<link name="base_footprint"/>

<!-- base_footprint -> body_link (fixed, lifts body above ground) -->
<joint name="body_link_joint" type="fixed">
    <parent link="base_footprint"/>
    <child  link="body_link"/>
    <origin xyz="0 0 ${s1}" rpy="0 0 0"/>   <!-- fixed: body now sits above ground -->
</joint>

<!-- Body link -->
<link name="body_link">
    <visual>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <geometry>
            <box size="${a} ${c} ${b}"/>
        </geometry>
    </visual>
    <collision>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <geometry>
            <box size="${a} ${c} ${b}"/>
        </geometry>
    </collision>
    <xacro:inertia_body/>
</link>

<!-- Wheel 1 - front left -->
<joint name="wheel1_joint" type="continuous">
    <parent link="body_link"/>
    <child  link="wheel1_link"/>
    <origin xyz="${-s2} ${-s4} ${-b/2}" rpy="0 0 0"/>   <!-- bottom of body, front, left -->
    <axis xyz="0 1 0"/>
    <limit effort="50000" velocity="10"/>
    <dynamics damping="1.0" friction="1.0"/>
</joint>

<link name="wheel1_link">
    <visual>
        <origin rpy="1.570795 0 0" xyz="0 0 0"/>
        <geometry>
            <cylinder length="${d}" radius="${r}"/>
        </geometry>
    </visual>
    <collision>
        <origin rpy="1.570795 0 0" xyz="0 0 0"/>
        <geometry>
            <cylinder length="${d}" radius="${r}"/>
        </geometry>
    </collision>
    <xacro:inertia_wheel/>
</link>

<!-- Wheel 2 - front right -->
<joint name="wheel2_joint" type="continuous">
    <parent link="body_link"/>
    <child  link="wheel2_link"/>
    <origin xyz="${-s2} ${s4} ${-b/2}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="50000" velocity="10"/>
    <dynamics damping="1.0" friction="1.0"/>
</joint>

<link name="wheel2_link">
    <visual>
        <origin rpy="1.570795 0 0" xyz="0 0 0"/>
        <geometry>
            <cylinder length="${d}" radius="${r}"/>
        </geometry>
    </visual>
    <collision>
        <origin rpy="1.570795 0 0" xyz="0 0 0"/>
        <geometry>
            <cylinder length="${d}" radius="${r}"/>
        </geometry>
    </collision>
    <xacro:inertia_wheel/>
</link>

<!-- Wheel 3 - rear left -->
<joint name="wheel3_joint" type="continuous">
    <parent link="body_link"/>
    <child  link="wheel3_link"/>
    <origin xyz="${s2} ${-s4} ${-b/2}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="50000" velocity="10"/>
    <dynamics damping="1.0" friction="1.0"/>
</joint>

<link name="wheel3_link">
    <visual>
        <origin rpy="1.570795 0 0" xyz="0 0 0"/>
        <geometry>
            <cylinder length="${d}" radius="${r}"/>
        </geometry>
    </visual>
    <collision>
        <origin rpy="1.570795 0 0" xyz="0 0 0"/>
        <geometry>
            <cylinder length="${d}" radius="${r}"/>
        </geometry>
    </collision>
    <xacro:inertia_wheel/>
</link>

<!-- Wheel 4 - rear right -->
<joint name="wheel4_joint" type="continuous">
    <parent link="body_link"/>
    <child  link="wheel4_link"/>
    <origin xyz="${s2} ${s4} ${-b/2}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="50000" velocity="10"/>
    <dynamics damping="1.0" friction="1.0"/>
</joint>

<link name="wheel4_link">
    <visual>
        <origin rpy="1.570795 0 0" xyz="0 0 0"/>
        <geometry>
            <cylinder length="${d}" radius="${r}"/>
        </geometry>
    </visual>
    <collision>
        <origin rpy="1.570795 0 0" xyz="0 0 0"/>
        <geometry>
            <cylinder length="${d}" radius="${r}"/>
        </geometry>
    </collision>
    <xacro:inertia_wheel/>
</link>

</robot>